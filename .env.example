# AI Provider Selection
# 'ollama' または 'lmstudio' を指定してください (デフォルト: ollama)
AI_PROVIDER=ollama

# --- Ollama Configuration ---
# 別のPCで実行している場合は http://<IPアドレス>:11434 と指定してください (例: http://192.168.1.10:11434)
OLLAMA_HOST=http://localhost:11434
# 使用したいモデル名を指定してください (デフォルト: gemma4:12b)
OLLAMA_MODEL=gemma4:12b
# コンテキストウィンドウサイズを指定してください (例: 65536 = 64k)
OLLAMA_CTX=65536

# --- LM Studio Configuration ---
# LM Studio のローカルサーバー URL を指定してください
LM_STUDIO_HOST=http://localhost:1234
# 使用したいモデル名を指定してください (LM Studio では多くの場合、ロードされているモデルが自動的に使用されます)
LM_STUDIO_MODEL=

# Port for the server to run on (optional)
PORT=3000